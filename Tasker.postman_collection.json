{
  "info": {
    "_postman_id": "d7e89fa7-8faf-483e-9aa1-bf20560ce6ea",
    "name": "Tasker",
    "description": "This collection contains all the API endpoints for the Task Management System built with Node.js, Express, and MongoDB. It includes authentication and task management APIs with role-based access control (RBAC).\n\nThe collection is organized into User and Task modules, covering features such as user registration, login, logout, task creation, assignment, updating, and deletion.\n\nProtected routes require a valid JWT token. After logging in, the access token is automatically stored in the environment variable and used for authorized requests.\n\nAdmin users have full access to all tasks and user data, while regular users can only access and manage their own assigned tasks.\n\nBase URL:  \n[http://localhost:8000/api/v1](http://localhost:8000/api/v1)\n\nEndFragment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "52630921",
    "_collection_link": "https://go.postman.co/collection/52630921-d7e89fa7-8faf-483e-9aa1-bf20560ce6ea?source=collection_link"
  },
